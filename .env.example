# Admin credentials (created on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password

# JWT
JWT_SECRET=change_me_jwt_secret_key_32_chars_min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for LLM API keys (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change_me_fernet_key_32url_safe_base64

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_DB=ai_bots
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Redis
REDIS_URL=redis://redis:6379/0

# Domain for CORS
DOMAIN=localhost

# SSL (for nginx)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
